# =============================================================================
# Nexus Dev Environment Configuration
# =============================================================================
# This is the env file for the DEV deployment (docker-compose.dev.yml).
# Copy to .env.dev and fill in values.
# For production, use .env with docker-compose.yml instead.
# =============================================================================

# Database credentials (separate from production)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-strong-password

# JWT Secret — use a DIFFERENT secret from production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret

# Dev domain — the subdomain Traefik routes to the dev stack.
# This drives CLIENT_URL, CORS, and the REACT_APP_SERVER_URL build arg.
# Example: dev.nexus.yourdomain.com
DEV_DOMAIN=dev.nexus.yourdomain.com

# Client URL — derived from DEV_DOMAIN when behind Traefik (HTTPS).
# Override only if you need a non-standard URL.
#   Behind Traefik:      https://dev.nexus.yourdomain.com  (set DEV_DOMAIN above)
#   Local without proxy:  http://localhost:3002
CLIENT_URL=https://dev.nexus.yourdomain.com

# Additional allowed CORS origins (comma-separated, optional)
# Useful if the dev frontend is accessible from multiple URLs.
# ALLOWED_ORIGINS=https://dev.nexus.yourdomain.com,http://localhost:3002

# Giphy API Key (optional, can share with prod)
# GIPHY_API_KEY=your-giphy-api-key-here

# Platform Admin — username that gets cross-server admin panel in Settings
# PLATFORM_ADMIN=yourusername

# =============================================================================
# Port mapping (reference — set in docker-compose.dev.yml, not here)
# =============================================================================
# Component        Dev Port   Prod Port   Container Port
# ─────────────    ────────   ─────────   ──────────────
# Client (Nginx)   3002       3000        80
# Server (Node)    3003       3001        3001
# PostgreSQL       5433       5432        5432
# Redis            6380       6379        6379
#
# When behind Traefik, the host ports (3002/3003) are not exposed publicly.
# Traefik routes https://DEV_DOMAIN → client:80 and /socket.io,/api → server:3001
# =============================================================================
