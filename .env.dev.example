# =============================================================================
# Nexus Dev Environment Configuration
# =============================================================================
# This is the env file for the DEV deployment (docker-compose.dev.yml).
# Copy to .env.dev and fill in values.
# For production, use .env with docker-compose.yml instead.
# =============================================================================

# Database credentials (separate from production)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-strong-password

# JWT Secret — use a DIFFERENT secret from production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret

# Client URL — the URL users access the DEV client in their browser.
# For dev behind a reverse proxy with a subdomain:
#   CLIENT_URL=https://dev.nexus.yourdomain.com
# For local dev access:
#   CLIENT_URL=http://localhost:3002
CLIENT_URL=http://localhost:3002

# Domain for Traefik dev deployment (used by docker-compose.dev.traefik.yml)
# DEV_DOMAIN=dev.nexus.yourdomain.com

# Additional allowed CORS origins (comma-separated, optional)
# ALLOWED_ORIGINS=https://dev.nexus.yourdomain.com

# Giphy API Key (optional, can share with prod)
# GIPHY_API_KEY=your-giphy-api-key-here

# Platform Admin — username that gets cross-server admin panel in Settings
# PLATFORM_ADMIN=yourusername

# =============================================================================
# Dev ports (reference only — set in docker-compose.dev.yml, not here)
# =============================================================================
# Client:    3002  (production uses 3000)
# Server:    3003  (production uses 3001)
# Postgres:  5433  (production uses 5432)
# Redis:     6380  (production uses 6379)
